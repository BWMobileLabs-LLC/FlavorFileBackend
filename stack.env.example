# ── Portainer ──────────────────────────────────────────────────────────────
# Add these in Stacks → your stack → Environment variables (one per line).
# Portainer substitutes ${VAR} into docker-compose.yml — no stack.env file needed.
#
# ── CLI ────────────────────────────────────────────────────────────────────
#   cp stack.env.example stack.env   # edit secrets, then:
#   docker compose --env-file stack.env up -d --build
#
# ── Cloudflare Tunnel ──────────────────────────────────────────────────────
#   Point the tunnel at http://127.0.0.1:3004  (must match PORT below)

PORT=3004

PGUSER=flavorfile
PGPASSWORD=change-me-use-a-long-random-password
PGDATABASE=flavorfile
PGPORT=5432

JWT_SECRET=change-me-use-a-long-random-secret
JWT_EXPIRES_IN=7d
