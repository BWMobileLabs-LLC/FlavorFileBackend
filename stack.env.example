# Copy this file to stack.env and fill in real values:
#   cp stack.env.example stack.env
#
# Deploy:
#   docker compose --env-file stack.env up -d --build
#
# Cloudflare Tunnel (on the host, not in this stack):
#   Point your tunnel service to http://127.0.0.1:3000
#   Example cloudflared config:
#     ingress:
#       - hostname: api.yourdomain.com
#         service: http://127.0.0.1:3000
#       - service: http_status:404

# App (PORT is the host port published to localhost for Cloudflare Tunnel)
PORT=3000

# PostgreSQL (used by both the db and app services)
PGUSER=flavorfile
PGPASSWORD=change-me-use-a-long-random-password
PGDATABASE=flavorfile
PGPORT=5432

# JWT
JWT_SECRET=change-me-use-a-long-random-secret
JWT_EXPIRES_IN=7d
